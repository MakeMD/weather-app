{
  "expo": {
    "name": "Weather App",
    "slug": "weather-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/branding/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/branding/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F5F1E8"
    },
    "ios": {
      "bundleIdentifier": "com.makemd.weatherapp",
      "supportsTablet": false,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSLocationWhenInUseUsageDescription": "We use your location to find the closest city for weather."
      }
    },
    "android": {
      "package": "com.makemd.weatherapp",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/branding/adaptive-icon.png",
        "backgroundColor": "#F5F1E8"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ]
    },
    "extra": {
      "eas": {
        "projectId": "80a5fe8a-0618-4e5b-86d2-02a787681105"
      }
    },
    "plugins": [
      "expo-localization",
      [
        "expo-notifications",
        {
          "color": "#3D3D3D"
        }
      ]
    ]
  }
}